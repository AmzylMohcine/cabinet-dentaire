{
  "name": "dentacare",
  "version": "1.0.0",
  "description": "DentaCare - Gestion de Cabinet Dentaire - Dr. EL KTAM MAROINE",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npx vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:react": "vite build",
    "build:win": "npm run build:react && electron-builder --win",
    "build:mac": "npm run build:react && electron-builder --mac",
    "build:all": "npm run build:react && electron-builder --win --mac",
    "build": "npm run build:react && electron-builder"
  },
  "build": {
    "appId": "com.dentacare.app",
    "productName": "DentaCare",
    "copyright": "Dr. EL KTAM MAROINE - Cabinet Dentaire",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon-512.png",
      "category": "public.app-category.medical"
    },
    "dmg": {
      "title": "DentaCare",
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DentaCare",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "dist-react/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "public/ordonnance-bg.jpg",
        "to": "ordonnance-bg.jpg"
      }
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "electron-store": "^8.2.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
